# JWT Authentication
# IMPORTANT: Must be at least 32 characters for HS256 algorithm
# Generate with: openssl rand -base64 48
JWT_SECRET=your-256-bit-secret-minimum-32-characters-change-in-production

# OAuth Feature Flags (optional)
OAUTH_GOOGLE_ENABLED=false
OAUTH_APPLE_ENABLED=false

# OAuth Credentials (only if enabled above)
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# OAUTH_APPLE_CLIENT_ID=your-apple-client-id
# OAUTH_APPLE_CLIENT_SECRET=your-apple-client-secret
