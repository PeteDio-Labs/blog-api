# =============================================================================
# Multi-stage Dockerfile for Local Development
# =============================================================================
# This Dockerfile is used for local development with docker-compose.
# It builds the JAR inside Docker, so you don't need to run mvn package locally.
#
# For production/CI/CD builds, use the main Dockerfile which expects a
# pre-built JAR in the target/ directory.
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build with Maven
# ---------------------------------------------------------------------------
FROM eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /build

# Copy Maven wrapper and pom.xml first (for better layer caching)
COPY .mvn/ .mvn/
COPY mvnw pom.xml ./

# Download dependencies BEFORE copying source code
# This layer is cached until pom.xml changes, speeding up rebuilds significantly
RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw dependency:resolve dependency:resolve-plugins -B

# Copy source code (changes frequently, so this is a separate layer)
COPY src/ src/

# Build the application (skip tests for faster builds)
# Dependencies already cached from previous step
RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw clean package -DskipTests

# ---------------------------------------------------------------------------
# Stage 2: Runtime
# ---------------------------------------------------------------------------
FROM eclipse-temurin:21-jre-alpine
WORKDIR /app

# Copy the built JAR from builder stage
COPY --from=builder /build/target/api-*.jar app.jar

# Optional: Add build metadata
ARG BUILD_DATE
LABEL build_date="${BUILD_DATE}"

EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
